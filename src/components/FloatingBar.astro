---
// Floating bar menu — replaces the conventional sticky header.
// Pattern reference: the owner's pick, awwwards.com/inspiration/floating-bar-menu
// (Eskapismus / 110% Magazine): a flat, solid-color bar floating over the page
// carrying the current section title, a section progress counter, and the menu
// trigger. Adapted to this site's forest-green/beige tokens and its
// zero-webfont rule (the editorial serif is a system Georgia stack).
// The menu itself is a <details> disclosure so navigation works without JS;
// the script only enhances (section tracking, close-on-navigate, Escape).
import ThemeToggle from "./ThemeToggle.astro";

// Tracked page sections, in DOM order. Label is what the bar displays.
const sections = [
  { id: "top", label: "Intro" },
  { id: "about", label: "About" },
  { id: "work", label: "Work" },
  { id: "projects", label: "Projects" },
  { id: "references", label: "References" },
  { id: "experience", label: "Experience" },
  { id: "skills", label: "Skills" },
  { id: "contact", label: "Contact" },
];

const navLinks = [
  { href: "#about", label: "About" },
  { href: "#work", label: "Work" },
  { href: "#projects", label: "Projects" },
  { href: "#experience", label: "Experience" },
  { href: "#skills", label: "Skills" },
  { href: "#contact", label: "Contact" },
];

const total = String(sections.length).padStart(2, "0");
---

<div class="float-top">
  <a href="#top" class="float-top__brand">Ciaran Fontein</a>
  <ThemeToggle />
</div>

<div class="float-bar" id="float-bar" data-sections={JSON.stringify(sections)}>
  <p class="float-bar__section" id="float-bar-section">Intro</p>

  <p class="float-bar__count" aria-hidden="true">
    <span id="float-bar-current">01</span>
    <span class="float-bar__track"
      ><span class="float-bar__fill" id="float-bar-fill"></span></span
    >
    <span>{total}</span>
  </p>

  <details class="float-bar__menu" id="float-bar-menu">
    <summary class="float-bar__trigger">
      <svg
        class="float-bar__squiggle"
        width="22"
        height="10"
        viewBox="0 0 22 10"
        fill="none"
        aria-hidden="true"
      >
        <path
          d="M1 7C3.5 2 6 2 8.5 5S13.5 8 16 5s3.5-3 5-1"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"></path>
      </svg>
      <span class="float-bar__trigger-label">Menu</span>
    </summary>

    <nav class="float-bar__panel" aria-label="Primary">
      <ul>
        {
          navLinks.map((link, i) => (
            <li>
              <a href={link.href}>
                <span class="float-bar__num" aria-hidden="true">
                  {String(i + 1).padStart(2, "0")}
                </span>
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="float-bar__top-link">
          <a href="#top">
            <span class="float-bar__num" aria-hidden="true">↑</span>
            Back to top
          </a>
        </li>
      </ul>
    </nav>
  </details>
</div>

<style>
  /* The fixed bottom bar overlays the end of the page; give the document
     breathing room so the footer is never permanently covered. */
  :global(body) {
    padding-bottom: 6.5rem;
  }

  /* --- floating top strip: brand + theme toggle, no band --- */
  .float-top {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 60;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.75rem var(--space-2);
    pointer-events: none;
  }

  .float-top > :global(*) {
    pointer-events: auto;
  }

  .float-top__brand {
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--color-text);
    text-decoration: none;
    background: color-mix(in srgb, var(--color-surface) 88%, transparent);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.4rem 0.9rem;
    box-shadow: var(--shadow-card);
  }

  .float-top__brand:hover {
    color: var(--color-accent-strong);
  }

  /* --- the floating bar --- */
  .float-bar {
    position: fixed;
    bottom: calc(1.1rem + env(safe-area-inset-bottom, 0px));
    left: 50%;
    transform: translateX(-50%);
    z-index: 60;
    display: flex;
    align-items: center;
    gap: 1.1rem;
    max-width: calc(100vw - 1.5rem);
    padding: 0.65rem 1.1rem;
    background: var(--color-accent-strong);
    color: var(--color-on-accent);
    border-radius: 4px;
    box-shadow: 0 10px 30px rgba(11, 48, 25, 0.35);
  }

  .float-bar__section {
    margin: 0;
    font-family: Georgia, "Iowan Old Style", "Times New Roman", serif;
    font-size: 1.02rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    min-width: 7.5ch;
  }

  .float-bar__count {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.78rem;
    font-weight: 600;
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.08em;
    opacity: 0.9;
    white-space: nowrap;
  }

  .float-bar__track {
    position: relative;
    width: 66px;
    height: 2px;
    background: color-mix(in srgb, currentColor 35%, transparent);
    overflow: hidden;
  }

  .float-bar__fill {
    position: absolute;
    inset: 0;
    background: currentColor;
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.35s ease;
  }

  /* --- menu disclosure --- */
  .float-bar__menu {
    position: relative;
    border-left: 1px solid color-mix(in srgb, currentColor 30%, transparent);
    padding-left: 1.1rem;
  }

  .float-bar__trigger {
    list-style: none;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    cursor: pointer;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    user-select: none;
  }

  .float-bar__trigger::-webkit-details-marker {
    display: none;
  }

  .float-bar__trigger:hover .float-bar__squiggle {
    transform: translateX(2px);
  }

  .float-bar__squiggle {
    transition: transform 0.2s ease;
  }

  .float-bar__panel {
    position: absolute;
    right: -1.1rem;
    bottom: calc(100% + 1.35rem);
    min-width: 15rem;
    background: var(--color-accent-strong);
    color: var(--color-on-accent);
    border-radius: 4px;
    box-shadow: 0 10px 30px rgba(11, 48, 25, 0.35);
    padding: 0.6rem 0;
  }

  .float-bar__panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .float-bar__panel a {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    padding: 0.55rem 1.3rem;
    color: inherit;
    text-decoration: none;
    font-family: Georgia, "Iowan Old Style", "Times New Roman", serif;
    font-size: 1.05rem;
    letter-spacing: 0.05em;
  }

  .float-bar__panel a:hover,
  .float-bar__panel a:focus-visible {
    background: color-mix(in srgb, currentColor 14%, transparent);
    color: inherit;
  }

  .float-bar__num {
    font-family: var(--font-sans);
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    opacity: 0.65;
    min-width: 1.6ch;
  }

  .float-bar__top-link {
    border-top: 1px solid color-mix(in srgb, currentColor 25%, transparent);
    margin-top: 0.4rem;
    padding-top: 0.4rem;
  }

  /* --- narrow screens --- */
  @media (max-width: 560px) {
    .float-bar {
      gap: 0.8rem;
      padding: 0.55rem 0.9rem;
      width: calc(100vw - 1.5rem);
      justify-content: space-between;
    }

    .float-bar__section {
      font-size: 0.92rem;
      min-width: 0;
      flex: 1;
    }

    .float-bar__track {
      width: 34px;
    }

    .float-bar__menu {
      padding-left: 0.8rem;
    }

    .float-bar__panel {
      right: -0.9rem;
    }
  }

  @media print {
    .float-top,
    .float-bar {
      display: none;
    }
  }
</style>

<script>
  // Progressive enhancement: section tracking + menu ergonomics.
  // Without JS the bar still shows, and <details> still opens the nav.
  const bar = document.getElementById("float-bar");
  const menu = document.getElementById("float-bar-menu") as HTMLDetailsElement | null;

  if (bar && menu) {
    const sections: { id: string; label: string }[] = JSON.parse(
      bar.dataset.sections || "[]",
    );
    const labelEl = document.getElementById("float-bar-section");
    const currentEl = document.getElementById("float-bar-current");
    const fillEl = document.getElementById("float-bar-fill");

    const setActive = (index: number) => {
      const s = sections[index];
      if (!s || !labelEl || !currentEl || !fillEl) return;
      labelEl.textContent = s.label;
      currentEl.textContent = String(index + 1).padStart(2, "0");
      const progress = sections.length > 1 ? index / (sections.length - 1) : 1;
      fillEl.style.transform = `scaleX(${progress})`;
    };

    // Track which section currently crosses the upper-middle of the viewport.
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (!entry.isIntersecting) continue;
          const index = sections.findIndex((s) => s.id === entry.target.id);
          if (index >= 0) setActive(index);
        }
      },
      { rootMargin: "-35% 0px -55% 0px" },
    );

    for (const s of sections) {
      const el = document.getElementById(s.id);
      if (el) observer.observe(el);
    }
    setActive(0);

    // Close the menu after navigating, on Escape, and on outside click.
    menu.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) menu.open = false;
    });
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.open) {
        menu.open = false;
        (menu.querySelector("summary") as HTMLElement | null)?.focus();
      }
    });
    document.addEventListener("click", (e) => {
      if (menu.open && !menu.contains(e.target as Node)) menu.open = false;
    });
  }
</script>
