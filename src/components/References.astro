---
// Verbatim excerpts from Ciaran's LinkedIn recommendations. Owner approved
// use ("use them freely") and supplied the full texts + job titles
// 2026-07-07. Trimming for length is allowed; remaining words stay verbatim.

const quotes = [
  {
    text: "I've had the pleasure of working with Ciaran over the last 6 years, and he's been an incredibly thoughtful, collaborative, and kind teammate. He played a foundational role in building the mobile app from the ground up, and his contributions have shaped the product in a lasting way.",
    name: "Sarah Tong",
    title: "Senior Product Designer & Web Developer at Guusto",
  },
  {
    text: "I'd be more than happy to recommend Ciaran to anyone looking for an exceptional mobile developer. He's not only a talented mobile engineer but also someone who's incredibly communicative, thoughtful, and easy to work with.",
    name: "Sreeja Guttula",
    title: "Junior Product Manager at Guusto",
  },
];
---

<section id="references" class="references">
  <div class="container">
    <h2 class="section-heading">What colleagues say</h2>
    <div class="references__grid">
      {
        quotes.map((q) => (
          <blockquote class="references__quote">
            <p>&ldquo;{q.text}&rdquo;</p>
            <footer>
              {q.name}, {q.title}
            </footer>
          </blockquote>
        ))
      }
    </div>
  </div>
</section>

<style>
  .references {
    padding-block: var(--space-4);
  }

  .references__grid {
    display: grid;
    gap: var(--space-3);
  }

  @media (min-width: 700px) {
    .references__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .references__quote {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: var(--space-3);
    margin: 0;
  }

  .references__quote p {
    color: var(--color-text);
    margin: 0 0 var(--space-2);
  }

  .references__quote footer {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }
</style>
