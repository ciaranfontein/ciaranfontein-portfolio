---
// Vertical edge rails — the reference's "FOLLOW 110%" / "FULLSCREEN" idiom:
// quiet rotated labels living on the page margins. Left rail carries the
// social links; right rail is a location wordmark. Desktop-only furniture —
// hidden below 1100px where the margins don't exist.
---

<div class="rails" aria-hidden="false">
  <div class="rails__left">
    <a href="https://github.com/ciaranfontein" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://linkedin.com/in/ciaranfontein" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <span class="rails__label" aria-hidden="true">Follow</span>
  </div>
  <p class="rails__right" aria-hidden="true">Nara · Japan</p>
</div>

<style>
  .rails {
    display: none;
  }

  @media (min-width: 1100px) {
    .rails {
      display: contents;
    }

    .rails__left,
    .rails__right {
      position: fixed;
      z-index: 40;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: 0.68rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.22em;
      color: var(--color-text-muted);
    }

    .rails__left {
      left: 1.1rem;
      bottom: 7rem;
      display: flex;
      flex-direction: column;
      gap: 1.2rem;
      align-items: center;
    }

    .rails__left a {
      color: var(--color-text-muted);
      text-decoration: none;
    }

    .rails__left a:hover {
      color: var(--color-accent-strong);
    }

    .rails__label {
      margin: 0;
    }

    .rails__label::before {
      content: "";
      display: block;
      width: 1px;
      height: 2.6rem;
      background: var(--color-border);
      margin: 0 auto 1.1rem;
    }

    .rails__right {
      right: 1.1rem;
      top: 50%;
      margin: 0;
    }
  }

  @media print {
    .rails {
      display: none;
    }
  }
</style>
