---
// Eye-tracking easter egg — ported from the original CRA site
// (adoption-report.md: src/components/Body/index.js + @react-hook/mouse-position).
//
// Mechanism (unchanged from the original):
//   - Base photo (CiaranNoEyes.png, eye sockets cut out) with sclera + two pupil
//     images layered on top, absolutely positioned over it.
//   - Pupils move within a small elliptical range toward the cursor: for each eye,
//     compute the vector from the eye's DOM center to the cursor, take
//     Math.atan2(dy, dx) for the angle, then offset the pupil by
//     cos(angle)*magL*magX, sin(angle)*magL*magY (per-eye magnitude constants).
//   - CSS transition on left/bottom gives the same 0.4s smoothing feel.
//
// Reimplemented here as a dependency-free vanilla TS island (no styled-components,
// no @react-hook/mouse-position) — a plain mousemove/touchmove listener does the
// same job. On touch devices there's no persistent pointer, so pupils idle-wander
// subtly and track the last touch point briefly on tap/drag.
// prefers-reduced-motion disables the animation (pupils rest at center).
//
// Pixel offsets below are calibrated to the source image at 1333x2000 (same
// dimensions as CiaranNoEyes.png) — if the headshot photo is ever swapped, these
// must be recalculated against the new crop.
import ciaranNoEyes from "../assets/CiaranNoEyes.png";
import eyeWhites from "../assets/EyeWhites.png";
import leftEyeImg from "../assets/LeftEye.png";
import rightEyeImg from "../assets/RightEye.png";
---

<div class="eye-tracker" id="eye-tracker">
  <div class="eye-tracker__stage">
    <img
      class="eye-tracker__base"
      src={ciaranNoEyes.src}
      width={ciaranNoEyes.width}
      height={ciaranNoEyes.height}
      alt="Ciaran Fontein"
      loading="eager"
      fetchpriority="high"
    />
    <img
      class="eye-tracker__sclera"
      src={eyeWhites.src}
      width={eyeWhites.width}
      height={eyeWhites.height}
      alt=""
      aria-hidden="true"
    />
    <img
      class="eye-tracker__pupil eye-tracker__pupil--left"
      id="pupil-left"
      src={leftEyeImg.src}
      width={leftEyeImg.width}
      height={leftEyeImg.height}
      alt=""
      aria-hidden="true"
    />
    <img
      class="eye-tracker__pupil eye-tracker__pupil--right"
      id="pupil-right"
      src={rightEyeImg.src}
      width={rightEyeImg.width}
      height={rightEyeImg.height}
      alt=""
      aria-hidden="true"
    />
    <!-- Invisible reference points marking each eye's socket center, same
         technique as the original LeftCenterPoint/RightCenterPoint divs. -->
    <div class="eye-tracker__center eye-tracker__center--left" id="center-left"></div>
    <div class="eye-tracker__center eye-tracker__center--right" id="center-right"></div>
  </div>
</div>

<style>
  .eye-tracker {
    position: relative;
    width: 100%;
    max-width: 320px;
    margin-inline: auto;
    aspect-ratio: 1333 / 2000;
  }

  .eye-tracker__stage {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    border-radius: 1.25rem;
    background: var(--color-bg-alt);
    box-shadow: var(--shadow-card);
  }

  .eye-tracker__base {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
    z-index: 1;
  }

  /* Percentage positions below are the original pixel offsets
     (bottom:523 left:763 out of a 1333x2000 frame, etc.) converted to % so the
     effect scales with the responsive image instead of relying on a fixed px canvas. */
  .eye-tracker__sclera {
    position: absolute;
    left: 57.24%; /* 763 / 1333 */
    bottom: 26.15%; /* 523 / 2000 */
    width: 18.45%; /* 246 / 1333 */
    z-index: 0;
    object-fit: contain;
  }

  .eye-tracker__pupil {
    position: absolute;
    width: 3.4%;
    z-index: 2;
    object-fit: contain;
    transition: left 0.4s, bottom 0.4s;
    transition-delay: 0.05s;
    will-change: left, bottom;
  }

  .eye-tracker__pupil--left {
    left: 61.89%; /* (825+10) / 1333, centered on socket */
    bottom: 26.2%;
  }

  .eye-tracker__pupil--right {
    left: 57.76%;
    bottom: 25.95%;
  }

  .eye-tracker__center {
    position: absolute;
    width: 0;
    height: 0;
  }

  .eye-tracker__center--left {
    left: 62.5%; /* 833 / 1333 */
    bottom: 26.55%; /* 531 / 2000 */
  }

  .eye-tracker__center--right {
    left: 58.36%; /* 778 / 1333 */
    bottom: 26.4%; /* 528 / 2000 */
  }

  @media (prefers-reduced-motion: reduce) {
    .eye-tracker__pupil {
      transition: none;
    }
  }
</style>

<script>
  import "../scripts/eye-tracking";
</script>
