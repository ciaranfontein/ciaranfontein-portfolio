---
import EyeTrackingHeadshot from "./EyeTrackingHeadshot.astro";
import { AVAILABILITY_BADGE, SITE } from "../site.config";
---

<section id="top" class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <p class="eyebrow">React Native Engineer</p>
      <h1>Ciaran Fontein</h1>
      <p class="hero__lede">
        I build mobile apps from Figma to the App Store. 6 years shipping
        Guusto's iOS + Android app as its sole frontend developer.
      </p>
      <p class="hero__meta">
        <span>📍 {SITE.location}</span>
        <span class="hero__badge">{AVAILABILITY_BADGE}</span>
        <span>{SITE.visaNote}</span>
      </p>
      <div class="hero__cta">
        <a class="button button--primary" href="#work">View my work ↓</a>
        <a class="button button--secondary" href="/resume/ciaran_fontein_cv.pdf" download>
          Download CV
        </a>
      </div>
    </div>
    <div class="hero__portrait">
      <EyeTrackingHeadshot />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-4) var(--space-5);
  }

  .hero__inner {
    display: grid;
    gap: var(--space-4);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-6);
    }
  }

  .hero h1 {
    font-size: clamp(2.25rem, 1.7rem + 2.5vw, 3.5rem);
    margin: 0.25rem 0 var(--space-2);
  }

  .hero__lede {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 42ch;
  }

  .hero__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    align-items: center;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    margin-block: var(--space-2) var(--space-3);
  }

  .hero__badge {
    display: inline-block;
    background: var(--color-badge-bg);
    color: var(--color-badge-text);
    font-weight: 600;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-size: 0.85rem;
  }

  .hero__cta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
  }

  .button--primary {
    background: var(--color-accent-strong);
    color: #fff;
  }

  .button--primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
  }

  .button--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .button--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  .hero__portrait {
    display: flex;
    justify-content: center;
  }
</style>
