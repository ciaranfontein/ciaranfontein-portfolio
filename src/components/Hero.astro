---
import { AVAILABILITY_BADGE, SITE } from "../site.config";
---

<section id="top" class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <a class="hero__announce" href="#projects">
        <span class="hero__announce-dot" aria-hidden="true"></span>
        New: KiraKiran, my own app, is live on the App Store
        <span aria-hidden="true">→</span>
      </a>
      <p class="eyebrow">Senior React Native Engineer</p>
      <h1>Ciaran Fontein</h1>
      <p class="hero__lede">
        I build mobile apps from Figma to the App Store — six years as the
        sole frontend developer on Guusto's iOS + Android app, and now
        shipping my own.
      </p>
      <ul class="hero__meta">
        <li>6+ years</li>
        <li>sole developer</li>
        <li>iOS + Android</li>
        <li>📍 {SITE.location}</li>
        <li>{SITE.visaNote}</li>
        <li class="hero__badge">{AVAILABILITY_BADGE}</li>
      </ul>
      <div class="hero__cta">
        <a class="button button--primary" href="#work">View my work ↓</a>
        <a class="button button--secondary" href="/resume/ciaran_fontein_cv.pdf" download>
          Download CV
        </a>
      </div>
    </div>
    <div class="hero__portrait">
      <img
        class="hero__photo"
        src="/images/headshot.webp"
        width="900"
        height="1350"
        alt="Ciaran Fontein"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-5) var(--space-6);
    background: linear-gradient(to bottom, var(--color-bg-alt), var(--color-bg));
    border-bottom: 1px solid var(--color-border);
  }

  .hero__announce {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 0.35rem 0.9rem;
    margin-bottom: var(--space-2);
    box-shadow: var(--shadow-card);
    transition: border-color 0.15s, transform 0.15s;
  }

  .hero__announce:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .hero__announce-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: #16a34a;
    flex-shrink: 0;
  }

  .hero__inner {
    display: grid;
    gap: var(--space-4);
    align-items: center;
  }

  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.2fr 0.8fr;
      gap: var(--space-6);
    }
  }

  .hero h1 {
    font-size: clamp(2.5rem, 1.8rem + 3vw, 4rem);
    letter-spacing: -0.02em;
    margin: 0.25rem 0 var(--space-2);
  }

  .hero__lede {
    font-size: 1.15rem;
    color: var(--color-text-muted);
    max-width: 42ch;
  }

  .hero__meta {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    font-size: 0.85rem;
    color: var(--color-badge-text);
    margin-block: var(--space-2) var(--space-3);
    padding: 0;
  }

  .hero__meta li {
    display: inline-block;
    background: var(--color-badge-bg);
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
  }

  .hero__badge {
    background: var(--color-accent-strong);
    color: var(--color-on-accent);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.7rem 1.4rem;
    border-radius: var(--radius);
    font-weight: 600;
    text-decoration: none;
    font-size: 0.95rem;
    transition: transform 0.15s, box-shadow 0.15s, background 0.15s;
  }

  .button--primary {
    background: var(--color-accent-strong);
    color: var(--color-on-accent);
  }

  .button--primary:hover {
    transform: translateY(-1px);
    box-shadow: var(--shadow-card);
  }

  .button--secondary {
    background: transparent;
    color: var(--color-text);
    border: 1px solid var(--color-border);
  }

  .button--secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent-strong);
  }

  .hero__portrait {
    display: flex;
    justify-content: center;
  }

  .hero__photo {
    width: min(320px, 70vw);
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }
</style>
