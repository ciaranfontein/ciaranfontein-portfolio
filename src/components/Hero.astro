---
// Swiss typographic hero — massive grotesque caps name, micro-label,
// plain large body text, underlined text links instead of buttons,
// B/W rectangular portrait. Reference: Aristide Benoist 2018 (owner-picked).
import { AVAILABILITY_BADGE, SITE } from "../site.config";

const meta = [
  "6+ years",
  "sole developer",
  "iOS + Android",
  SITE.location,
  SITE.visaNote,
  AVAILABILITY_BADGE,
];
---

<section id="top" class="hero">
  <div class="container hero__inner">
    <div class="hero__copy">
      <a class="hero__announce" href="#projects">
        New: three of my own apps are live on the App Store&nbsp;<span
          aria-hidden="true">→</span>
      </a>
      <p class="eyebrow">Profile<br />Senior React Native Engineer</p>
      <h1 class="hero__name">Ciaran<br />Fontein</h1>
      <p class="hero__lede">
        I build mobile apps from Figma to the App Store. Six years as the
        sole frontend developer on Guusto's iOS + Android app, and now
        shipping my own.
      </p>
      <p class="hero__meta">
        {meta.join("  ·  ")}
      </p>
      <div class="hero__cta">
        <a class="hero__link" href="#work">View my work</a>
        <a class="hero__link" href="/resume/ciaran_fontein_cv.pdf" download>
          Download CV
        </a>
      </div>
    </div>
    <div class="hero__portrait">
      <img
        class="hero__photo"
        src="/images/headshot.webp"
        width="900"
        height="1350"
        alt="Ciaran Fontein"
        fetchpriority="high"
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: var(--space-6) var(--space-6);
  }

  .hero__inner {
    display: grid;
    gap: var(--space-4);
    align-items: end;
  }

  @media (min-width: 900px) {
    .hero__inner {
      grid-template-columns: 1.4fr 0.6fr;
      gap: var(--space-6);
    }
  }

  .hero__announce {
    display: inline-block;
    font-size: 0.62rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    text-decoration: none;
    margin-bottom: var(--space-4);
  }

  .hero__announce:hover {
    color: var(--color-text);
    text-decoration: underline;
  }

  .hero__name {
    font-weight: 800;
    text-transform: uppercase;
    font-size: clamp(3.4rem, 1rem + 11vw, 9rem);
    letter-spacing: -0.03em;
    line-height: 0.9;
    margin: var(--space-2) 0 var(--space-4);
  }

  .hero__lede {
    font-size: clamp(1.15rem, 1rem + 0.7vw, 1.45rem);
    line-height: 1.45;
    max-width: 46ch;
    margin: 0 0 var(--space-3);
  }

  .hero__meta {
    font-size: 0.78rem;
    font-weight: 500;
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 0 var(--space-3);
  }

  .hero__cta {
    display: flex;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .hero__link {
    font-size: 0.95rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    color: var(--color-text);
    text-decoration: underline;
    text-underline-offset: 0.35em;
    text-decoration-thickness: 2px;
  }

  .hero__link:hover {
    color: var(--color-accent-strong);
  }

  .hero__portrait {
    display: flex;
    justify-content: flex-end;
  }

  /* B/W rectangular image, no chrome — color returns on hover */
  .hero__photo {
    width: min(300px, 62vw);
    height: auto;
    filter: grayscale(1);
    transition: filter 0.25s ease;
  }

  .hero__photo:hover {
    filter: grayscale(0);
  }

  @media (max-width: 899px) {
    .hero__portrait {
      justify-content: flex-start;
    }
  }
</style>
