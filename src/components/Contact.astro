---
import { RESUME_FILES, SITE } from "../site.config";
---

<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-heading">Contact</h2>
    <p class="contact__cta">
      I'm interviewing for senior React Native roles starting August 2026.
      Email me.
    </p>
    <ul class="contact__links">
      <li>
        <a href={`mailto:${SITE.email}?subject=${encodeURIComponent("React Native role")}`}>
          {SITE.email}
        </a>
      </li>
      <li>
        <a href={SITE.github} target="_blank" rel="noopener noreferrer">
          {SITE.githubHandle}
        </a>
      </li>
      <li>
        <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer">
          {SITE.linkedinHandle}
        </a>
      </li>
    </ul>

    <h3 class="contact__resume-heading">Resume downloads</h3>
    <p class="contact__jp-intro" lang="ja">
      奈良在住のシニアReact Nativeエンジニア。ビザスポンサー不要、2026年8月より就業可能。日本語の履歴書・職務経歴書は下記よりダウンロードいただけます。
    </p>
    <div class="contact__resumes">
      {
        RESUME_FILES.map((file) => (
          <div class="contact__resume" lang={file.lang}>
            <span class="contact__resume-label">{file.label}</span>
            <span class="contact__resume-sub">{file.sublabel}</span>
            <span class="contact__resume-formats">
              {file.formats.map((f) => (
                <a href={f.href} download>
                  {f.ext}
                </a>
              ))}
            </span>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact__cta {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--space-3);
  }

  .contact__links {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 1.1rem;
  }

  .contact__resume-heading {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .contact__jp-intro {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 0 var(--space-3);
  }

  .contact__resumes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .contact__resume {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.7rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    color: var(--color-text);
  }

  .contact__resume-label {
    font-weight: 600;
  }

  .contact__resume-sub {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .contact__resume-formats {
    display: flex;
    gap: 0.6rem;
    margin-top: 0.35rem;
    font-size: 0.85rem;
    font-weight: 600;
  }
</style>
