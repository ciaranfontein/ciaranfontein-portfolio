---
import { RESUME_FILES, SITE } from "../site.config";
---

<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-heading">Contact</h2>
    <ul class="contact__links">
      <li>
        <a href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </li>
      <li>
        <a href={SITE.github} target="_blank" rel="noopener noreferrer">
          {SITE.githubHandle}
        </a>
      </li>
      <li>
        <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer">
          {SITE.linkedinHandle}
        </a>
      </li>
    </ul>

    <h3 class="contact__resume-heading">Resume downloads</h3>
    <div class="contact__resumes">
      {
        RESUME_FILES.map((file) => (
          <a class="contact__resume" href={file.href} download lang={file.lang}>
            <span class="contact__resume-label">{file.label}</span>
            <span class="contact__resume-sub">{file.sublabel}</span>
          </a>
        ))
      }
    </div>
  </div>
</section>

<style>
  .contact__links {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-size: 1.1rem;
  }

  .contact__resume-heading {
    font-size: 1rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .contact__resumes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .contact__resume {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    padding: 0.7rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--color-text);
    transition: border-color 0.15s, transform 0.15s;
  }

  .contact__resume:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
  }

  .contact__resume-label {
    font-weight: 600;
  }

  .contact__resume-sub {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }
</style>
